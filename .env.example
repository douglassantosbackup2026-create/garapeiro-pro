# Credenciais do Supabase (Settings → API)
VITE_SUPABASE_URL=https://juzevbpkzmaccujvmujo.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sua-chave-anon
VITE_SUPABASE_PROJECT_ID=juzevbpkzmaccujvmujo

# Funil quiz (/quiz)
# VITE_APP_CADASTRO_URL=/cadastro
# Meta Pixel (Lead / InitiateCheckout / Purchase no funil)
VITE_META_PIXEL_ID=

# Mercado Pago — Checkout Bricks (Payment Brick + Status Screen)
# Credenciais de TESTE no painel: https://www.mercadopago.com.br/developers/panel/app
# Prefixo TEST- (Bricks / Payments API) ou APP_USR- — use o que o painel emitir.
VITE_MP_PUBLIC_KEY=TEST-xxxxxxxx

# Secrets só no servidor (Supabase → Edge Functions → Secrets), NÃO no Vite:
#   npx supabase secrets set MP_ACCESS_TOKEN=TEST-xxxxxxxx --project-ref juzevbpkzmaccujvmujo
#   npx supabase secrets set MP_WEBHOOK_SECRET=sua-assinatura-secreta --project-ref juzevbpkzmaccujvmujo
#   npx supabase secrets set ALLOWED_ORIGINS=https://seudominio.com,http://localhost:5173 --project-ref juzevbpkzmaccujvmujo
#
# Sem MP_WEBHOOK_SECRET o webhook é rejeitado (fail-closed).
# Sem ALLOWED_ORIGINS só localhost é aceito nas Edge Functions (exceto webhooks sem Origin).
#
# Upload dos PDFs do Playbook (bucket privado `playbook`):
#   node scripts/upload-playbook.mjs   # requer SUPABASE_SERVICE_ROLE_KEY no .env
#
# Webhook URL (tópico Payments) no painel MP:
#   https://juzevbpkzmaccujvmujo.supabase.co/functions/v1/mercado-pago/webhook
